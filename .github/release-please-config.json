{
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "json",
          "path": "typescript/package.json",
          "jsonpath": "version"
        },
        {
          "type": "toml",
          "path": "rust/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "yaml",
          "path": "compose.yml",
          "jsonpath": "$.services['utaaf-app'].image"
        }
      ]
    }
  },
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
